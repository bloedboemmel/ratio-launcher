<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RatioLauncher" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/ratio_black</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/ratio_black</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="colorPrimary">@color/ratio_accent</item>
        <item name="colorOnPrimary">@color/ratio_black</item>
        <item name="colorSurface">@color/ratio_black</item>
        <item name="colorOnSurface">@color/ratio_white</item>
        <item name="android:fontFamily">@font/inter_regular</item>
    </style>

    <style name="Theme.RatioLauncher.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/ratio_accent</item>
        <item name="colorSurface">@color/ratio_card_bg</item>
        <item name="colorOnSurface">@color/ratio_white</item>
        <item name="android:windowBackground">@color/ratio_card_bg</item>
    </style>
</resources>
