<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ratio_black"
    android:orientation="vertical"
    android:paddingTop="80dp"
    android:paddingHorizontal="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Screen Time"
        android:textColor="@color/ratio_white"
        android:textSize="28sp"
        android:fontFamily="@font/ratio_light"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/usageTotalTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/ratio_gray_text"
        android:textSize="14sp"
        android:fontFamily="@font/inter_light"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="APPS"
        android:textColor="@color/ratio_gray_light"
        android:textSize="10sp"
        android:fontFamily="@font/inter_medium"
        android:letterSpacing="0.2"
        android:layout_marginBottom="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/usageAppList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="32dp" />

</LinearLayout>
