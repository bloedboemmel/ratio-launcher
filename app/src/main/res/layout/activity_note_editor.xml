<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ratio_black"
    android:orientation="vertical"
    android:paddingTop="80dp"
    android:paddingHorizontal="32dp"
    android:paddingBottom="32dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Note"
            android:textColor="@color/ratio_white"
            android:textSize="24sp"
            android:fontFamily="@font/ratio_light" />

        <TextView
            android:id="@+id/noteDeleteBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="DELETE"
            android:textColor="@color/ratio_gray_light"
            android:textSize="12sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.1"
            android:paddingHorizontal="16dp" />

        <TextView
            android:id="@+id/noteSaveBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="SAVE"
            android:textColor="@color/ratio_accent"
            android:textSize="12sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.1"
            android:paddingHorizontal="16dp" />

    </LinearLayout>

    <!-- Editor -->
    <EditText
        android:id="@+id/noteEditorText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:textColor="@color/ratio_white"
        android:textColorHint="@color/ratio_gray_light"
        android:textSize="16sp"
        android:fontFamily="@font/inter_light"
        android:hint="Write something..."
        android:background="@null"
        android:gravity="top|start"
        android:inputType="textMultiLine|textCapSentences"
        android:lineSpacingExtra="4dp" />

</LinearLayout>
