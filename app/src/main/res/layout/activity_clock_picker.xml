<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ratio_black"
    android:orientation="vertical"
    android:gravity="center">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose clock style"
        android:textColor="@color/ratio_white"
        android:textSize="20sp"
        android:fontFamily="@font/ratio_light"
        android:layout_marginBottom="32dp" />

    <!-- Horizontal scrollable clock previews -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/clockPickerList"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:clipToPadding="false"
        android:paddingHorizontal="48dp"
        android:overScrollMode="never" />

    <!-- Style name -->
    <TextView
        android:id="@+id/clockPickerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/ratio_accent"
        android:textSize="14sp"
        android:fontFamily="@font/inter_medium"
        android:layout_marginTop="24dp" />

    <!-- Select button -->
    <TextView
        android:id="@+id/clockPickerSelect"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="SELECT"
        android:textColor="@color/ratio_accent"
        android:textSize="14sp"
        android:fontFamily="@font/inter_medium"
        android:letterSpacing="0.1"
        android:paddingHorizontal="32dp"
        android:layout_marginTop="24dp" />

</LinearLayout>
