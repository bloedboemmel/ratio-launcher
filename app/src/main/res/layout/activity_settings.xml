<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ratio_black"
    android:fillViewport="true"
    android:scrollbars="none"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="80dp"
        android:paddingBottom="48dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/ratio_white"
            android:textSize="32sp"
            android:fontFamily="@font/ratio_light"
            android:layout_marginBottom="40dp" />

        <!-- GENERAL SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GENERAL"
            android:textColor="@color/ratio_accent"
            android:textSize="10sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="16dp" />

        <!-- Theme -->
        <LinearLayout
            android:id="@+id/settingTheme"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Theme"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:id="@+id/settingThemeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark"
                android:textColor="@color/ratio_gray_text"
                android:textSize="13sp"
                android:fontFamily="@font/inter_light" />
        </LinearLayout>

        <!-- Clock style -->
        <LinearLayout
            android:id="@+id/settingClockStyle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clock style"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:id="@+id/settingClockStyleValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Minimal"
                android:textColor="@color/ratio_gray_text"
                android:textSize="13sp"
                android:fontFamily="@font/inter_light" />
        </LinearLayout>

        <!-- Show seconds -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show seconds"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/settingsShowSeconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- 24h Format -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="24-hour format"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/settingsClock24h"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Double tap to lock -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Double-tap to lock"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/settingsDoubleTapLock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Hide status bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hide status bar"
                    android:textColor="@color/ratio_white"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter_regular" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Icons still visible"
                    android:textColor="@color/ratio_gray_light"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter_light" />

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/settingsHideStatusBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/gray_70"
            android:layout_marginVertical="24dp" />

        <!-- TILES SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TILES"
            android:textColor="@color/ratio_accent"
            android:textSize="10sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="16dp" />

        <!-- Grayscale icons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Grayscale icons"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/settingsMonochrome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Tile size -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Large tiles"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/settingsLargeTiles"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Icon pack -->
        <LinearLayout
            android:id="@+id/settingIconPack"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Icon pack"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:id="@+id/settingIconPackValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Default"
                android:textColor="@color/ratio_gray_text"
                android:textSize="13sp"
                android:fontFamily="@font/inter_light" />
        </LinearLayout>

        <!-- Reorder categories -->
        <LinearLayout
            android:id="@+id/settingReorderCategories"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reorder categories"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="@color/ratio_gray_text"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Hidden apps -->
        <LinearLayout
            android:id="@+id/settingHiddenApps"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hidden apps"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:id="@+id/settingHiddenAppsCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/ratio_gray_text"
                android:textSize="13sp"
                android:fontFamily="@font/inter_light" />
        </LinearLayout>

        <!-- Backup/Restore -->
        <LinearLayout
            android:id="@+id/settingBackup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Backup &amp; Restore"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="@color/ratio_gray_text"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/gray_70"
            android:layout_marginVertical="24dp" />

        <!-- DIGITAL WELLBEING SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DIGITAL WELLBEING"
            android:textColor="@color/ratio_accent"
            android:textSize="10sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="16dp" />

        <!-- Usage goal -->
        <LinearLayout
            android:id="@+id/settingUsageGoal"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Daily screen time goal"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:id="@+id/settingUsageGoalValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4h"
                android:textColor="@color/ratio_gray_text"
                android:textSize="13sp"
                android:fontFamily="@font/inter_light" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/gray_70"
            android:layout_marginVertical="24dp" />

        <!-- WEATHER SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WEATHER"
            android:textColor="@color/ratio_accent"
            android:textSize="10sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="16dp" />

        <!-- Temperature unit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Temperature unit"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:id="@+id/settingTempUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="°C"
                android:textColor="@color/ratio_gray_text"
                android:textSize="13sp"
                android:fontFamily="@font/inter_light" />
        </LinearLayout>

        <!-- City -->
        <EditText
            android:id="@+id/settingsCity"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="City name"
            android:textColor="@color/ratio_white"
            android:textColorHint="@color/ratio_gray_light"
            android:textSize="15sp"
            android:fontFamily="@font/inter_light"
            android:background="@drawable/note_input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:inputType="text"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/gray_70"
            android:layout_marginVertical="24dp" />

        <!-- ROOT CARDS SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ROOT CARDS"
            android:textColor="@color/ratio_accent"
            android:textSize="10sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="16dp" />

        <!-- Reorder Root cards -->
        <LinearLayout
            android:id="@+id/settingReorderCards"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reorder cards"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="@color/ratio_gray_text"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Show music -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Now playing"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/settingsShowMusic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Show calendar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Calendar"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/settingsShowCalendar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Show weather -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Weather"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/settingsShowWeather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Show notes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Notes"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/settingsShowNotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Show screen time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Screen time"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/settingsShowScreenTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/gray_70"
            android:layout_marginVertical="24dp" />

        <!-- Restart onboarding -->
        <LinearLayout
            android:id="@+id/settingOnboarding"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show intro / permissions"
                android:textColor="@color/ratio_white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="@color/ratio_gray_text"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- FEEDBACK -->
        <LinearLayout
            android:id="@+id/settingSendFeedback"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Send feedback"
                android:textColor="@color/ratio_accent"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="@color/ratio_gray_text"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/gray_70"
            android:layout_marginVertical="24dp" />

        <!-- ABOUT SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABOUT"
            android:textColor="@color/ratio_accent"
            android:textSize="10sp"
            android:fontFamily="@font/inter_medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ratio Launcher"
            android:textColor="@color/ratio_white"
            android:textSize="15sp"
            android:fontFamily="@font/inter_regular" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Open source recreation of Blloc Ratio"
            android:textColor="@color/ratio_gray_text"
            android:textSize="13sp"
            android:fontFamily="@font/inter_light"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/settingsVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.0"
            android:textColor="@color/ratio_gray_light"
            android:textSize="12sp"
            android:fontFamily="@font/inter_light"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
