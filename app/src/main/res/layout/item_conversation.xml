<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="10dp"
    android:paddingHorizontal="4dp">

    <ImageView
        android:id="@+id/convAppIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:contentDescription="App"
        android:alpha="0.6" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/convSender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ratio_white"
            android:textSize="15sp"
            android:fontFamily="@font/inter_medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/convMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ratio_gray_text"
            android:textSize="13sp"
            android:fontFamily="@font/inter_light"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/convTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/ratio_gray_light"
        android:textSize="11sp"
        android:fontFamily="@font/inter_light" />

</LinearLayout>
